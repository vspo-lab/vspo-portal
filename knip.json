{
  "workspaces": {
    "packages/api": {
      "project": "**/*.ts"
    },
    "packages/dayjs": {
      "project": "**/*.ts"
    },
    "packages/errors": {
      "project": "**/*.ts"
    },
    "packages/logging": {
      "project": "**/*.ts"
    },
    "service/vspo-schedule/v2/web": {
      "entry": ["src/pages/**/*.{ts,tsx}", "next.config.{js,mjs,ts}"],
      "project": "**/*.{ts,tsx}"
    }
  },
  "ignoreDependencies": [
    "@textlint/textlint-plugin-markdown",
    "textlint-rule-preset-ja-technical-writing"
  ]
}
