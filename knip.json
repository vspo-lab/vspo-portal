{
  "workspaces": {
    "packages/api": {
      "project": "**/*.ts"
    },
    "packages/dayjs": {
      "project": "**/*.ts"
    },
    "packages/errors": {
      "project": "**/*.ts"
    },
    "packages/logging": {
      "project": "**/*.ts"
    },
    "service/vspo-schedule/v2/web": {
      "entry": [
        "src/pages/**/*.{ts,tsx}",
        "next.config.{js,mjs,ts}",
        "open-next.config.ts",
        "src/lib/i18n.ts"
      ],
      "project": "**/*.{ts,tsx}",
      "ignore": [
        "src/features/multiview/**",
        "src/features/shared/types/api.d.ts"
      ]
    }
  },
  "ignoreDependencies": [
    "@textlint/textlint-plugin-markdown",
    "textlint-rule-common-misspellings",
    "textlint-rule-preset-ja-technical-writing"
  ],
  "ignoreBinaries": ["wrangler", "report"],
  "ignoreWorkspaces": ["service/bot-dashboard"]
}
