{
  "name": "vspo-portal",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "turbo build",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint --apply .",
    "biome:unsafe-fix": "biome check --fix --unsafe",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "tsc": "pnpm -r exec tsc --noEmit",
    "generate-openapi": "pnpm --filter @vspo-lab/api generate-openapi",
    "dev:vspo-schedule-web": "pnpm --filter vspo-schedule-v2-web dev",
    "textlint": "textlint \"{README.md,docs/**/*.md}\"",
    "textlint:fix": "textlint --fix \"{README.md,docs/**/*.md}\"",
    "security-scan": "./scripts/security-scan.sh",
    "security-scan:docker": "./scripts/security-scan.sh --docker"
  },
  "author": "sugar-cat7",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@textlint/textlint-plugin-markdown": "^15.5.2",
    "@types/node": "catalog:",
    "knip": "^5.86.0",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "pnpm": ">=9.15.9",
    "node": ">=22.12.0"
  }
}
