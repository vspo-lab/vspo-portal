---
import AvatarFallback from "~/components/ui/AvatarFallback.astro";
import Button from "~/components/ui/Button.astro";
import type { GuildSummaryType } from "~/features/guild/domain/guild";
import { GuildSummary } from "~/features/guild/domain/guild";
import { t } from "~/i18n/dict";

interface Props {
  guild: GuildSummaryType;
  botClientId: string;
}

const { guild, botClientId } = Astro.props;
const { locale } = Astro.locals;
const iconUrl = GuildSummary.iconUrl(guild);
---

<div class:list={[
  "rounded-2xl p-6 transition-all duration-200",
  guild.botInstalled
    ? "bg-surface-container hover:bg-surface-container-high"
    : "bg-surface-container-low opacity-70",
]}>
  <div class="mb-4 flex items-center gap-3">
    <AvatarFallback src={iconUrl} name={guild.name} size="md" />
    <div class="min-w-0 flex-1">
      <h3 class="truncate text-base font-semibold leading-none text-on-surface">
        {guild.name}
      </h3>
      {guild.botInstalled ? (
        <div class="mt-1.5 flex items-center gap-1.5">
          <div class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
          </div>
          <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-400">
            {t(locale, "guild.active")}
          </span>
        </div>
      ) : (
        <span class="mt-1 inline-block text-xs text-on-surface-variant">
          {t(locale, "dashboard.notInstalled")}
        </span>
      )}
    </div>
  </div>

  {guild.botInstalled && guild.channelSummary && (
    <div class="mb-4">
      <p class="text-xs text-on-surface-variant">
        {t(locale, "dashboard.channelsCount", {
          total: String(guild.channelSummary.totalCount),
        })}
      </p>
      {guild.channelSummary.previewNames.length > 0 && (
        <div class="mt-1.5 flex flex-wrap gap-1">
          {guild.channelSummary.previewNames.map((name) => (
            <span class="rounded bg-surface-container-highest px-2 py-0.5 text-xs text-on-surface-variant">
              #{name}
            </span>
          ))}
        </div>
      )}
    </div>
  )}

  <div>
    {
      guild.botInstalled ? (
        <Button
          as="a"
          href={`/dashboard/${guild.id}`}
          variant="default"
          size="sm"
          class="w-full rounded-xl bg-gradient-to-r from-vspo-purple to-vspo-purple-light font-bold text-white shadow-lg shadow-vspo-purple/20 transition-all hover:scale-[1.02] active:scale-95"
        >
          {t(locale, "guild.manageSettings")}
        </Button>
      ) : (
        <Button
          as="a"
          href={GuildSummary.inviteUrl(guild, botClientId)}
          variant="outline"
          size="sm"
          class="w-full rounded-xl"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t(locale, "guild.addBot")}
        </Button>
      )
    }
  </div>
</div>
