---
import AvatarFallback from "~/components/ui/AvatarFallback.astro";
import Button from "~/components/ui/Button.astro";
import Card from "~/components/ui/Card.astro";
import type { GuildSummaryType } from "~/features/guild/domain/guild";
import { GuildSummary } from "~/features/guild/domain/guild";
import { t } from "~/i18n/dict";

interface Props {
  guild: GuildSummaryType;
  botClientId: string;
}

const { guild, botClientId } = Astro.props;
const { locale } = Astro.locals;
const iconUrl = GuildSummary.iconUrl(guild);
---

<Card class={`transition-all duration-[--duration-fast] ease-[--ease-standard] ${guild.botInstalled ? "hover-lift" : "border-dashed opacity-80"}`}>
  <div class="flex flex-row items-center gap-3 p-4 pb-2 sm:p-6 sm:pb-2">
    <AvatarFallback src={iconUrl} name={guild.name} size="md" />
    <div class="min-w-0 flex-1">
      <h3 class="truncate text-base font-semibold leading-none tracking-tight">
        {guild.name}
      </h3>
      {guild.botInstalled ? (
        <span class="mt-1 inline-block rounded-full bg-vspo-purple/20 px-2 py-0.5 text-xs text-foreground">
          Bot {t(locale, "guild.active")}
        </span>
      ) : (
        <span class="mt-1 inline-block rounded-full bg-muted px-2 py-0.5 text-xs text-muted-foreground">
          {t(locale, "dashboard.notInstalled")}
        </span>
      )}
    </div>
  </div>
  {guild.botInstalled && guild.channelSummary && (
    <div class="px-4 pb-2 sm:px-6">
      <p class="text-xs text-muted-foreground">
        {t(locale, "guild.channelSummary", {
          enabled: String(guild.channelSummary.enabledCount),
          total: String(guild.channelSummary.totalCount),
        })}
      </p>
      {guild.channelSummary.previewNames.length > 0 && (
        <div class="mt-1 flex flex-wrap gap-1">
          {guild.channelSummary.previewNames.map((name) => (
            <span class="rounded-full bg-muted px-2 py-0.5 text-xs text-muted-foreground">
              #{name}
            </span>
          ))}
        </div>
      )}
    </div>
  )}
  <div class="p-4 pt-2 sm:p-6 sm:pt-2">
    {
      guild.botInstalled ? (
        <Button
          as="a"
          href={`/dashboard/${guild.id}`}
          variant="default"
          size="sm"
          class="w-full"
        >
          {t(locale, "guild.manageSettings")}
        </Button>
      ) : (
        <Button
          as="a"
          href={GuildSummary.inviteUrl(guild, botClientId)}
          variant="outline"
          size="sm"
          class="w-full"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t(locale, "guild.addBot")}
        </Button>
      )
    }
  </div>
</Card>
