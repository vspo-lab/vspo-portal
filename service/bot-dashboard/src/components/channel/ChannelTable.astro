---
import type { ChannelConfigType } from "~/features/channel/domain/channel-config";
import { t, memberTypeKey, languageDisplayKey } from "~/i18n/dict";

interface Props {
  channels: ChannelConfigType[];
  guildId: string;
}

const { channels, guildId } = Astro.props;
const { locale } = Astro.locals;

/** Language code to chip label */
const langChipLabel = (lang: string) => lang === "ja" ? "JA" : lang === "en" ? "EN" : lang.toUpperCase();
---

{/* Configuration Matrix */}
<div class="overflow-hidden rounded-2xl bg-surface-container-low">
  {/* Table header bar */}
  <div class="flex items-center justify-between bg-surface-container-low px-6 py-5 sm:px-8">
    <h3 class="font-heading text-lg font-bold text-on-surface">{t(locale, "channel.table")}</h3>
    <a
      href="?add=true"
      class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-vspo-purple to-vspo-purple-light px-5 py-2.5 font-heading text-sm font-bold text-white shadow-lg shadow-vspo-purple/20 transition-all hover:scale-[1.03] active:scale-95"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      {t(locale, "channel.add")}
    </a>
  </div>

  {/* Table */}
  <div class="overflow-x-auto">
    <table class="w-full text-left" aria-label={t(locale, "channel.table")}>
      <thead>
        <tr class="bg-surface-container-high text-[10px] font-bold uppercase tracking-[0.12em] text-on-surface-variant">
          <th scope="col" class="px-6 py-4 sm:px-8">{t(locale, "channel.name")}</th>
          <th scope="col" class="hidden px-6 py-4 sm:table-cell sm:px-8">{t(locale, "channel.language")}</th>
          <th scope="col" class="hidden px-6 py-4 md:table-cell sm:px-8">{t(locale, "channel.members")}</th>
          <th scope="col" class="hidden px-6 py-4 lg:table-cell sm:px-8">{t(locale, "channel.status")}</th>
          <th scope="col" class="px-6 py-4 text-right sm:px-8">{t(locale, "channel.actions")}</th>
        </tr>
      </thead>
      <tbody>
        {
          channels.map((ch, i) => (
            <tr class:list={[
              "group transition-colors duration-200",
              i % 2 === 0 ? "bg-surface" : "bg-surface-container-lowest",
              "hover:bg-surface-container-highest/30",
            ]}>
              <td class="px-6 py-4 sm:px-8">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-vspo-purple/10 text-vspo-purple">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" /></svg>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-on-surface">{ch.channelName}</p>
                    <p class="text-[10px] text-on-surface-variant/60">{ch.channelId}</p>
                  </div>
                </div>
              </td>
              <td class="hidden px-6 py-4 sm:table-cell sm:px-8">
                <span class="rounded bg-surface-container-highest px-2.5 py-1 text-[10px] font-bold text-on-surface">
                  {langChipLabel(ch.language)}
                </span>
              </td>
              <td class="hidden px-6 py-4 text-xs font-medium text-on-surface-variant md:table-cell sm:px-8">
                {t(locale, memberTypeKey(ch.memberType))}
              </td>
              <td class="hidden px-6 py-4 lg:table-cell sm:px-8">
                {ch.enabled ? (
                  <div class="flex items-center gap-2">
                    <div class="relative flex h-2 w-2">
                      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                      <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                    </div>
                    <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-400">{t(locale, "channel.status.active")}</span>
                  </div>
                ) : (
                  <div class="flex items-center gap-2">
                    <span class="inline-flex h-2 w-2 rounded-full bg-on-surface-variant/40"></span>
                    <span class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant/60">{t(locale, "channel.status.paused")}</span>
                  </div>
                )}
              </td>
              <td class="px-6 py-4 sm:px-8">
                <div class="flex items-center justify-end gap-2 opacity-100 transition-opacity md:opacity-40 md:group-hover:opacity-100 md:group-focus-within:opacity-100">
                  <a
                    href={`?edit=${ch.channelId}`}
                    class="rounded-lg p-2 text-on-surface-variant transition-colors hover:text-vspo-purple focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vspo-purple/50"
                    aria-label={`${t(locale, "channel.edit")} #${ch.channelName}`}
                  >
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                  </a>
                  <a
                    href={`?delete=${ch.channelId}`}
                    class="rounded-lg p-2 text-on-surface-variant transition-colors hover:text-destructive focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-destructive/50"
                    aria-label={`${t(locale, "channel.delete")} #${ch.channelName}`}
                  >
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                  </a>
                </div>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  {/* Empty state */}
  {
    channels.length === 0 && (
      <div class="flex flex-col items-center gap-3 p-12 text-center">
        <svg class="h-12 w-12 text-on-surface-variant/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
        </svg>
        <p class="text-sm text-on-surface-variant">
          {t(locale, "channel.empty")}
        </p>
        <a
          href="?add=true"
          class="mt-2 inline-flex items-center gap-1.5 rounded-lg px-4 py-2 text-sm font-medium text-vspo-purple transition-colors hover:bg-vspo-purple/10"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          {t(locale, "channel.add")}
        </a>
      </div>
    )
  }
</div>
