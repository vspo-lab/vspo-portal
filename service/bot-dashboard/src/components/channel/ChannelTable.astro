---
import { actions } from "astro:actions";
import type { ChannelConfigType } from "~/features/channel/domain/channel-config";
import { t, memberTypeKey } from "~/i18n/dict";

interface Props {
  channels: ChannelConfigType[];
  guildId: string;
}

const { channels, guildId } = Astro.props;
const { locale } = Astro.locals;
---

<div class="overflow-x-auto rounded-[--radius] border border-border">
  <table class="w-full text-sm" aria-label={t(locale, "channel.table")}>
    <thead>
      <tr class="border-b border-border bg-muted">
        <th scope="col" class="px-4 py-3 text-left font-semibold">{t(locale, "channel.name")}</th>
        <th scope="col" class="px-4 py-3 text-left font-semibold">{t(locale, "channel.enabled")}</th>
        <th scope="col" class="hidden px-4 py-3 text-left font-semibold sm:table-cell">{t(locale, "channel.language")}</th>
        <th scope="col" class="hidden px-4 py-3 text-left font-semibold md:table-cell">{t(locale, "channel.members")}</th>
        <th scope="col" class="px-4 py-3 text-right font-semibold">{t(locale, "channel.actions")}</th>
      </tr>
    </thead>
    <tbody>
      {
        channels.map((ch) => (
          <tr class="border-b border-border last:border-0">
            <td class="px-4 py-3 font-medium">#{ch.channelName}</td>
            <td class="px-4 py-3">
              <form
                method="post"
                action={actions.toggleChannel}
              >
                <input type="hidden" name="guildId" value={guildId} />
                <input type="hidden" name="channelId" value={ch.channelId} />
                <input type="hidden" name="enable" value={ch.enabled ? "false" : "true"} />
                <button
                  type="submit"
                  role="switch"
                  aria-checked={ch.enabled ? "true" : "false"}
                  class={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors duration-[--duration-fast] ease-[--ease-standard] ${ch.enabled ? "bg-vspo-purple" : "bg-muted"}`}
                  aria-label={t(locale, ch.enabled ? "channel.disable" : "channel.enable")}
                >
                  <span
                    class={`inline-block h-4 w-4 rounded-full bg-white transition-transform duration-[--duration-fast] ease-[--ease-standard] ${ch.enabled ? "translate-x-6" : "translate-x-1"}`}
                  />
                </button>
              </form>
            </td>
            <td class="hidden px-4 py-3 text-muted-foreground sm:table-cell">
              {ch.language.toUpperCase()}
            </td>
            <td class="hidden px-4 py-3 text-muted-foreground md:table-cell">
              {t(locale, memberTypeKey(ch.memberType))}
            </td>
            <td class="px-4 py-3 text-right">
              <a
                href={`?edit=${ch.channelId}`}
                class="inline-flex items-center gap-1 rounded-[--radius-sm] border border-border px-3 py-1 text-sm text-muted-foreground transition-colors duration-[--duration-fast] ease-[--ease-standard] hover:bg-accent hover:text-accent-foreground"
                aria-label={`${t(locale, "channel.edit")} #${ch.channelName}`}
              >
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                {t(locale, "channel.edit")}
              </a>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
  {
    channels.length === 0 && (
      <p class="p-6 text-center text-muted-foreground">
        {t(locale, "channel.empty")}
      </p>
    )
  }
</div>
