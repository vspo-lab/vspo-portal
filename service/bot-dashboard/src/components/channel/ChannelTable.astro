---
import type { ChannelConfigType } from "~/features/channel/domain/channel-config";
import { t, memberTypeKey, languageDisplayKey } from "~/i18n/dict";

interface Props {
  channels: ChannelConfigType[];
  guildId: string;
}

const { channels, guildId } = Astro.props;
const { locale } = Astro.locals;
---

<div class="overflow-x-auto rounded-[--radius] border border-border">
  <table class="w-full text-sm" aria-label={t(locale, "channel.table")}>
    <thead>
      <tr class="border-b border-border bg-muted">
        <th scope="col" class="px-4 py-3 text-left font-semibold">{t(locale, "channel.name")}</th>
        <th scope="col" class="hidden px-4 py-3 text-left font-semibold sm:table-cell">{t(locale, "channel.language")}</th>
        <th scope="col" class="hidden px-4 py-3 text-left font-semibold md:table-cell">{t(locale, "channel.members")}</th>
        <th scope="col" class="px-4 py-3 text-right font-semibold">{t(locale, "channel.actions")}</th>
      </tr>
    </thead>
    <tbody>
      {
        channels.map((ch) => (
          <tr class="border-b border-border transition-colors duration-[--duration-fast] last:border-0 hover:bg-accent/50">
            <td class="px-4 py-3 font-medium">#{ch.channelName}</td>
            <td class="hidden px-4 py-3 text-muted-foreground sm:table-cell">
              {t(locale, languageDisplayKey(ch.language))}
            </td>
            <td class="hidden px-4 py-3 text-muted-foreground md:table-cell">
              {t(locale, memberTypeKey(ch.memberType))}
            </td>
            <td class="px-4 py-3">
              <div class="flex items-center justify-end gap-2">
                <a
                  href={`?edit=${ch.channelId}`}
                  class="inline-flex min-h-9 cursor-pointer items-center gap-1.5 rounded-[--radius-sm] border border-border px-3 py-1.5 text-sm text-muted-foreground transition-colors duration-[--duration-fast] ease-[--ease-standard] hover:bg-accent hover:text-accent-foreground"
                  aria-label={`${t(locale, "channel.edit")} #${ch.channelName}`}
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                  {t(locale, "channel.edit")}
                </a>
                <a
                  href={`?delete=${ch.channelId}`}
                  class="inline-flex min-h-9 cursor-pointer items-center gap-1.5 rounded-[--radius-sm] border border-destructive/40 px-3 py-1.5 text-sm text-destructive transition-colors duration-[--duration-fast] ease-[--ease-standard] hover:bg-destructive/10"
                  aria-label={`${t(locale, "channel.delete")} #${ch.channelName}`}
                >
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                  {t(locale, "channel.delete")}
                </a>
              </div>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
  {
    channels.length === 0 && (
      <div class="flex flex-col items-center gap-3 p-8 text-center">
        <svg class="h-12 w-12 text-muted-foreground/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
        </svg>
        <p class="text-sm text-muted-foreground">
          {t(locale, "channel.empty")}
        </p>
      </div>
    )
  }
  <div class="flex justify-end border-t border-border px-4 py-3">
    <a
      href={`?add=true`}
      class="inline-flex items-center gap-1.5 rounded-[--radius-sm] bg-vspo-purple px-4 py-2 text-sm font-medium text-white transition-colors duration-[--duration-fast] ease-[--ease-standard] hover:bg-vspo-purple/90"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      {t(locale, "channel.add")}
    </a>
  </div>
</div>
