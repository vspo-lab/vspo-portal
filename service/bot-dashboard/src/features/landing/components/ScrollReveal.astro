---
import { z } from "zod";

/**
 * ScrollReveal — CSS-only scroll-triggered animations using animation-timeline.
 *
 * @precondition Animation keyframes must be defined in app.css.
 * @postcondition Element animates when scrolled into view (CSS only, no JS).
 *
 * @example
 * <ScrollReveal animation="fade-in-up">
 *   <p>This fades in on scroll</p>
 * </ScrollReveal>
 */
const propsSchema = z.object({
  /** Animation type matching [data-scroll-reveal] CSS selectors */
  animation: z.enum(["fade-in-up"]),
  /** Delay in ms before animation starts */
  delay: z.number().optional(),
  /** HTML tag to render */
  tag: z.string().optional(),
  /** Additional CSS classes */
  class: z.string().optional(),
});
type Props = z.infer<typeof propsSchema>;

const {
  animation,
  delay = 0,
  tag = "div",
  class: className = "",
} = Astro.props;

const Tag = tag;
---

<Tag
  data-scroll-reveal={animation}
  style={delay > 0 ? `--reveal-delay: ${delay}ms` : undefined}
  class={className}
>
  <slot />
</Tag>
