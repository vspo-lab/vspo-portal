---
import { LanguageSelectorIsland } from "~/features/shared/components/LanguageSelectorIsland";
import { ThemeToggle } from "~/features/shared/components/ThemeToggle";
import { UserMenuIsland } from "~/features/auth/components/UserMenuIsland";
import { t } from "~/i18n/dict";

type Props = {
  user?: { displayName: string; avatarUrl: string | null } | null;
};

const { user = null } = Astro.props;
const { locale } = Astro.locals;
const returnTo = Astro.url.pathname + Astro.url.search;

const localeLabels = {
  ja: t(locale, "settings.language.ja"),
  en: t(locale, "settings.language.en"),
};
---

<header class="sticky top-0 z-50 flex h-14 items-center justify-between border-b border-border/50 bg-surface/80 px-4 backdrop-blur-lg sm:px-6">
  <div class="flex items-center gap-4">
    <slot name="left" />
    <a href={user ? "/dashboard" : "/"} class="font-heading text-lg font-bold tracking-tight text-vspo-purple">
      {t(locale, "app.name")}
    </a>
  </div>
  <div class="flex items-center gap-2">
    <LanguageSelectorIsland
      client:idle
      currentLocale={locale}
      returnTo={returnTo}
      label={t(locale, "settings.language")}
      localeLabels={localeLabels}
    />
    <ThemeToggle client:load label={t(locale, "settings.theme.toggle")} />
    {user && (
      <UserMenuIsland
        client:idle
        displayName={user.displayName}
        avatarUrl={user.avatarUrl}
        translations={{
          language: t(locale, "settings.language"),
          theme: t(locale, "settings.theme"),
          logout: t(locale, "auth.logout"),
        }}
        localeLabels={localeLabels}
        currentLocale={locale}
        returnTo={returnTo}
      />
    )}
  </div>
</header>
