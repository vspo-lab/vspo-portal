---
import Base from "~/layouts/Base.astro";
import Button from "~/components/ui/Button.astro";
import Card from "~/components/ui/Card.astro";

if (Astro.locals.user) {
  return Astro.redirect("/dashboard");
}
---

<Base title="ログイン">
  <div
    class="flex min-h-screen flex-col items-center justify-center gap-8 p-4"
  >
    <div class="flex flex-col items-center gap-4 text-center">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Spodule Bot Dashboard
      </h1>
      <p class="max-w-lg text-lg text-muted-foreground">
        Discord Bot の配信通知設定を Web から簡単に管理できます。
        チャンネルごとの言語やメンバーフィルターをひと目で確認・変更。
      </p>
    </div>

    <a href="/auth/discord">
      <Button variant="discord" size="lg" class="gap-2 text-base">
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
          ></path>
        </svg>
        Discord でログイン
      </Button>
    </a>

    <div class="grid max-w-2xl gap-4 sm:grid-cols-3">
      <Card>
        <div class="flex flex-col space-y-1.5 p-6 pb-2">
          <h3 class="text-base font-semibold leading-none tracking-tight">
            一覧管理
          </h3>
        </div>
        <div class="p-6 pt-0">
          <p class="text-sm text-muted-foreground">
            サーバーとチャンネルの設定をひと目で確認
          </p>
        </div>
      </Card>
      <Card>
        <div class="flex flex-col space-y-1.5 p-6 pb-2">
          <h3 class="text-base font-semibold leading-none tracking-tight">
            メンバーフィルター
          </h3>
        </div>
        <div class="p-6 pt-0">
          <p class="text-sm text-muted-foreground">
            JP・EN・カスタムで通知対象を細かく設定
          </p>
        </div>
      </Card>
      <Card>
        <div class="flex flex-col space-y-1.5 p-6 pb-2">
          <h3 class="text-base font-semibold leading-none tracking-tight">
            即座に反映
          </h3>
        </div>
        <div class="p-6 pt-0">
          <p class="text-sm text-muted-foreground">
            Web から変更するだけで Bot に即座に反映
          </p>
        </div>
      </Card>
    </div>
  </div>
</Base>
