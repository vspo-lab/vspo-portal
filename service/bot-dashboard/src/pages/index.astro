---
import Base from "~/layouts/Base.astro";
import Button from "~/components/ui/Button.astro";
import Card from "~/components/ui/Card.astro";
import LanguageSelector from "~/components/ui/LanguageSelector.astro";
import ThemeToggle from "~/components/ui/ThemeToggle.astro";
import { t } from "~/i18n/dict";

if (Astro.locals.user) {
  return Astro.redirect("/dashboard");
}

const locale = Astro.locals.locale;

const errorParam = Astro.url.searchParams.get("error");
const errorKey = errorParam === "auth_failed" || errorParam === "no_code" || errorParam === "fetch_failed" || errorParam === "invalid_state"
  ? (`error.${errorParam}` as const)
  : null;
---

<Base
  title={t(locale, "login.title")}
  description={t(locale, "login.description")}
  canonicalPath="/"
>
  <main
    id="main-content"
    class="bg-grid relative flex min-h-screen flex-col items-center justify-center gap-6 overflow-hidden p-4 sm:gap-10"
  >
    {/* Background glow */}
    <div
      class="pointer-events-none absolute left-1/2 top-1/3 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-vspo-purple/5 blur-[100px] dark:bg-vspo-purple/15"
      aria-hidden="true"
    ></div>

    {/* Page settings */}
    <nav aria-label="Page settings" class="absolute right-4 top-4 flex items-center gap-2">
      <LanguageSelector currentLocale={locale} returnTo="/" variant="dropdown" />
      <ThemeToggle variant="page" />
    </nav>

    {/* Hero */}
    <div class="flex flex-col items-center gap-5 text-center">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-vspo-purple/10 px-3 py-1 text-sm font-medium text-foreground dark:bg-vspo-purple/20">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
        </svg>
        {t(locale, "app.name")}
      </span>
      <h1 class="font-heading text-4xl font-bold tracking-tight sm:text-5xl">
        {t(locale, "login.headline")}
      </h1>
      <p class="max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg" style="text-wrap: balance;">
        {t(locale, "login.description")}
      </p>
    </div>

    {/* Error */}
    {errorKey && (
      <div class="flex w-full max-w-lg items-start gap-3 rounded-[--radius-sm] border border-destructive bg-destructive/10 p-4 text-sm text-foreground" role="alert">
        <svg class="mt-0.5 h-4 w-4 shrink-0 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <div class="flex-1">
          <p>{t(locale, errorKey)}</p>
          <a href="/auth/discord" class="mt-1 inline-block font-medium text-vspo-purple underline hover:no-underline">
            {t(locale, "login.button")}
          </a>
        </div>
        <button type="button" class="shrink-0 cursor-pointer p-1 text-muted-foreground hover:text-foreground" aria-label={t(locale, "toast.dismiss")}
          onclick="this.closest('[role=alert]')?.remove()">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
    )}

    {/* Feature cards */}
    <section aria-label="Features" class="grid w-full max-w-2xl gap-3 sm:gap-4 sm:grid-cols-3">
      <Card class="animate-fade-in-up border-t-2 border-t-vspo-purple/30">
        <div class="flex items-center gap-3 p-4 sm:flex-col sm:items-start sm:gap-0 sm:space-y-2 sm:p-6 sm:pb-2">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[--radius-sm] bg-vspo-purple/10 ring-1 ring-vspo-purple/20 dark:bg-vspo-purple/20 sm:h-12 sm:w-12">
            <svg class="h-5 w-5 text-vspo-purple sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
          </div>
          <div class="min-w-0 sm:hidden">
            <h2 class="text-sm font-semibold">{t(locale, "login.feature.list")}</h2>
            <p class="text-xs text-muted-foreground">{t(locale, "login.feature.list.desc")}</p>
          </div>
          <h2 class="hidden text-base font-semibold leading-none tracking-tight sm:block">
            {t(locale, "login.feature.list")}
          </h2>
        </div>
        <div class="hidden p-6 pt-0 sm:block">
          <p class="text-sm text-muted-foreground">
            {t(locale, "login.feature.list.desc")}
          </p>
        </div>
      </Card>
      <Card class="animate-fade-in-up border-t-2 border-t-vspo-purple/30" style="animation-delay: 100ms;">
        <div class="flex items-center gap-3 p-4 sm:flex-col sm:items-start sm:gap-0 sm:space-y-2 sm:p-6 sm:pb-2">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[--radius-sm] bg-vspo-purple/10 ring-1 ring-vspo-purple/20 dark:bg-vspo-purple/20 sm:h-12 sm:w-12">
            <svg class="h-5 w-5 text-vspo-purple sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
          </div>
          <div class="min-w-0 sm:hidden">
            <h2 class="text-sm font-semibold">{t(locale, "login.feature.filter")}</h2>
            <p class="text-xs text-muted-foreground">{t(locale, "login.feature.filter.desc")}</p>
          </div>
          <h2 class="hidden text-base font-semibold leading-none tracking-tight sm:block">
            {t(locale, "login.feature.filter")}
          </h2>
        </div>
        <div class="hidden p-6 pt-0 sm:block">
          <p class="text-sm text-muted-foreground">
            {t(locale, "login.feature.filter.desc")}
          </p>
        </div>
      </Card>
      <Card class="animate-fade-in-up border-t-2 border-t-vspo-purple/30" style="animation-delay: 200ms;">
        <div class="flex items-center gap-3 p-4 sm:flex-col sm:items-start sm:gap-0 sm:space-y-2 sm:p-6 sm:pb-2">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[--radius-sm] bg-vspo-purple/10 ring-1 ring-vspo-purple/20 dark:bg-vspo-purple/20 sm:h-12 sm:w-12">
            <svg class="h-5 w-5 text-vspo-purple sm:h-6 sm:w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div class="min-w-0 sm:hidden">
            <h2 class="text-sm font-semibold">{t(locale, "login.feature.realtime")}</h2>
            <p class="text-xs text-muted-foreground">{t(locale, "login.feature.realtime.desc")}</p>
          </div>
          <h2 class="hidden text-base font-semibold leading-none tracking-tight sm:block">
            {t(locale, "login.feature.realtime")}
          </h2>
        </div>
        <div class="hidden p-6 pt-0 sm:block">
          <p class="text-sm text-muted-foreground">
            {t(locale, "login.feature.realtime.desc")}
          </p>
        </div>
      </Card>
    </section>

    {/* CTA */}
    <div class="flex flex-col items-center gap-3">
      <Button as="a" href="/auth/discord" rel="noopener" variant="discord" size="lg" class="h-14 max-w-full gap-3 rounded-xl px-10 text-lg shadow-action transition-all duration-[--duration-fast] ease-[--ease-standard] hover:shadow-hover hover:brightness-110">
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
          ></path>
        </svg>
        {t(locale, "login.button")}
      </Button>
      <p class="text-xs text-muted-foreground">
        {t(locale, "login.permissions_note")}
      </p>
    </div>

    {/* Footer */}
    <footer class="mt-auto pt-6 text-center text-xs text-muted-foreground">
      <span>vspo-schedule.com</span>
    </footer>
  </main>
</Base>
