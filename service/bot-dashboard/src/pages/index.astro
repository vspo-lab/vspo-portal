---
import Base from "~/layouts/Base.astro";
import Button from "~/components/ui/Button.astro";
import LanguageSelector from "~/components/ui/LanguageSelector.astro";
import ThemeToggle from "~/components/ui/ThemeToggle.astro";
import { t } from "~/i18n/dict";

if (Astro.locals.user) {
  return Astro.redirect("/dashboard");
}

const locale = Astro.locals.locale;

const errorParam = Astro.url.searchParams.get("error");
const errorKey = errorParam === "auth_failed" || errorParam === "no_code" || errorParam === "fetch_failed" || errorParam === "invalid_state"
  ? (`error.${errorParam}` as const)
  : null;
---

<Base
  title={t(locale, "login.title")}
  description={t(locale, "meta.login.description")}
  canonicalPath="/"
>
  <div class="min-h-screen bg-surface text-on-surface">
    {/* Top Navigation */}
    <nav class="sticky top-0 z-50 flex h-16 items-center justify-between px-6 bg-surface">
      <div class="flex items-center gap-8">
        <span class="text-xl font-bold font-heading tracking-tight text-vspo-purple">{t(locale, "app.name")}</span>
      </div>
      <div class="flex items-center gap-2">
        <LanguageSelector currentLocale={locale} returnTo="/" variant="header" />
        <ThemeToggle variant="page" />
      </div>
    </nav>

    <main id="main-content" class="relative">
      {/* Hero Section */}
      <section class="relative overflow-hidden px-6 pb-16 pt-16 sm:pb-32 sm:pt-24">
        {/* Background glow */}
        <div class="pointer-events-none absolute left-1/2 top-0 h-[600px] w-[1200px] -translate-x-1/2 opacity-30" aria-hidden="true">
          <div class="absolute inset-0 rounded-full bg-gradient-to-b from-vspo-purple to-transparent blur-[120px]"></div>
        </div>

        <div class="relative z-10 mx-auto flex max-w-7xl flex-col items-center text-center">
          {/* Version badge */}
          <div class="mb-8 inline-flex items-center gap-2 rounded-full bg-surface-container-highest px-3 py-1">
            <div class="h-2 w-2 rounded-full bg-emerald-400 glow-pulse text-emerald-400"></div>
            <span class="text-xs font-medium tracking-wide text-vspo-purple">{t(locale, "app.name")}</span>
          </div>

          {/* Headline */}
          <h1 class="mb-6 max-w-4xl font-heading text-5xl font-extrabold tracking-tight text-on-surface sm:text-6xl md:text-7xl" style="line-height: 0.95;">
            {t(locale, "login.headline")}
          </h1>

          <p class="mb-12 max-w-2xl text-lg leading-relaxed text-on-surface-variant sm:text-xl" style="text-wrap: balance;">
            {t(locale, "login.description")}
          </p>

          {/* Error */}
          {errorKey && (
            <div class="mb-8 flex w-full max-w-lg items-start gap-3 rounded-xl bg-destructive/10 p-4 text-sm text-on-surface" role="alert">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
              <div class="flex-1">
                <p>{t(locale, errorKey)}</p>
                <a href="/auth/discord" class="mt-1 inline-block font-medium text-vspo-purple underline hover:no-underline">
                  {t(locale, "login.button")}
                </a>
              </div>
              <button type="button" class="shrink-0 cursor-pointer p-1 text-on-surface-variant hover:text-on-surface" aria-label={t(locale, "toast.dismiss")}
                onclick="this.closest('[role=alert]')?.remove()">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
            </div>
          )}

          {/* CTA Buttons */}
          <div class="flex flex-col items-center gap-4 sm:flex-row">
            <Button
              as="a"
              href="/auth/discord"
              rel="noopener"
              variant="discord"
              size="lg"
              class="h-14 gap-3 rounded-xl bg-gradient-to-r from-vspo-purple to-[#bec2ff] px-8 text-lg font-bold text-white shadow-lg shadow-vspo-purple/20 transition-all hover:scale-[1.02] active:scale-95"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
              </svg>
              {t(locale, "login.button")}
            </Button>
            <p class="text-xs text-on-surface-variant">
              {t(locale, "login.permissions_note")}
            </p>
          </div>
        </div>
      </section>

      {/* Discord notification preview */}
      <section class="relative px-6 pb-8 sm:pb-16">
        <div class="mx-auto max-w-5xl">
          <p class="mb-8 text-center text-sm text-on-surface-variant">{t(locale, "login.previewCaption")}</p>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div class="group relative">
              <div class="absolute inset-0 rounded-2xl bg-vspo-purple/10 blur-2xl transition-opacity group-hover:bg-vspo-purple/20" aria-hidden="true"></div>
              <img
                src="/discord-preview-1.png"
                alt={t(locale, "login.previewCaption")}
                class="relative rounded-xl shadow-hover"
                loading="lazy"
                width="580"
                height="1024"
              />
            </div>
            <div class="group relative">
              <div class="absolute inset-0 rounded-2xl bg-vspo-purple/10 blur-2xl transition-opacity group-hover:bg-vspo-purple/20" aria-hidden="true"></div>
              <img
                src="/discord-preview-2.png"
                alt={t(locale, "login.previewCaption")}
                class="relative rounded-xl shadow-hover"
                loading="lazy"
                width="580"
                height="1024"
              />
            </div>
          </div>
        </div>
      </section>

      {/* Feature Bento Grid */}
      <section class="bg-surface-container-lowest px-6 py-16 sm:py-32">
        <div class="mx-auto max-w-7xl">
          <div class="mb-16 text-left">
            <h2 class="mb-4 font-heading text-3xl font-extrabold tracking-tight sm:text-4xl">{t(locale, "login.features")}</h2>
            <p class="max-w-xl text-lg text-on-surface-variant">{t(locale, "login.features.desc")}</p>
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-12">
            {/* Large feature card (8 cols) */}
            <div class="group relative overflow-hidden rounded-xl bg-surface-container-low p-8 md:col-span-8">
              <div class="relative z-10">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-vspo-purple/10">
                  <svg class="h-6 w-6 text-vspo-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
                  </svg>
                </div>
                <h3 class="mb-2 font-heading text-2xl font-bold">{t(locale, "login.feature.list")}</h3>
                <p class="max-w-md text-on-surface-variant">{t(locale, "login.feature.list.desc")}</p>
              </div>
              {/* Decorative gradient */}
              <div class="absolute -bottom-10 -right-10 h-48 w-48 rounded-full bg-gradient-to-br from-vspo-purple to-transparent opacity-20 blur-3xl transition-opacity group-hover:opacity-40" aria-hidden="true"></div>
            </div>

            {/* Small feature card (4 cols) */}
            <div class="rounded-xl bg-surface-container p-8 transition-colors hover:bg-surface-container-high md:col-span-4">
              <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-tertiary/10">
                <svg class="h-6 w-6 text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                </svg>
              </div>
              <h3 class="mb-2 font-heading text-xl font-bold">{t(locale, "login.feature.filter")}</h3>
              <p class="text-sm leading-relaxed text-on-surface-variant">{t(locale, "login.feature.filter.desc")}</p>
            </div>

            {/* Small feature card (4 cols) */}
            <div class="rounded-xl bg-surface-container p-8 transition-colors hover:bg-surface-container-high md:col-span-4">
              <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-vspo-purple/10">
                <svg class="h-6 w-6 text-vspo-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="mb-2 font-heading text-xl font-bold">{t(locale, "login.feature.realtime")}</h3>
              <p class="text-sm leading-relaxed text-on-surface-variant">{t(locale, "login.feature.realtime.desc")}</p>
            </div>

            {/* Medium feature card (8 cols) */}
            <div class="group relative flex items-center gap-8 overflow-hidden rounded-xl bg-surface-container-high p-8 md:col-span-8">
              <div class="flex-1">
                <h3 class="mb-2 font-heading text-2xl font-bold">{t(locale, "guild.manageSettings")}</h3>
                <p class="text-on-surface-variant">{t(locale, "login.feature.filter.desc")}</p>
              </div>
              <div class="absolute -bottom-10 -right-10 h-48 w-48 rounded-full bg-gradient-to-br from-vspo-purple to-transparent opacity-10 blur-3xl transition-opacity group-hover:opacity-30" aria-hidden="true"></div>
            </div>
          </div>
        </div>
      </section>

      {/* CTA Section */}
      <section class="relative px-6 py-16 sm:py-24">
        <div class="relative mx-auto max-w-5xl overflow-hidden rounded-2xl bg-gradient-to-br from-vspo-purple/20 to-surface-container-low p-12 text-center md:p-24">
          <div class="pointer-events-none absolute inset-0 opacity-30" aria-hidden="true">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-vspo-purple/30 via-transparent to-transparent"></div>
          </div>
          <h2 class="relative z-10 mb-6 font-heading text-4xl font-extrabold md:text-5xl">{t(locale, "login.cta.headline")}</h2>
          <p class="relative z-10 mx-auto mb-10 max-w-xl text-lg text-on-surface-variant">{t(locale, "login.cta.description")}</p>
          <div class="relative z-10 flex flex-col justify-center gap-4 sm:flex-row">
            <Button
              as="a"
              href="/auth/discord"
              rel="noopener"
              variant="discord"
              size="lg"
              class="rounded-xl bg-gradient-to-r from-vspo-purple to-[#bec2ff] px-10 py-5 font-bold text-white transition-all hover:scale-105 active:scale-95"
            >
              {t(locale, "login.button")}
            </Button>
          </div>
        </div>
      </section>

      {/* Footer */}
      <footer class="px-6 py-12">
        <div class="mx-auto flex max-w-7xl items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="font-heading text-xl font-bold tracking-tight text-vspo-purple">{t(locale, "app.name")}</span>
            <span class="text-xs text-on-surface-variant opacity-60">{t(locale, "login.footer")}</span>
          </div>
        </div>
      </footer>
    </main>
  </div>
</Base>
