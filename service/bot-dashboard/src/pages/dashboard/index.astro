---
import { env } from "cloudflare:workers";
import GuildCard from "~/components/guild/GuildCard.astro";
import Dashboard from "~/layouts/Dashboard.astro";
import { ListGuildsUsecase } from "~/features/guild/usecase/list-guilds";
import { t } from "~/i18n/dict";

const locale = Astro.locals.locale;
const accessToken = Astro.locals.accessToken;
if (!accessToken) {
  return Astro.redirect("/");
}

const result = await ListGuildsUsecase.execute({
  accessToken,
  appWorker: env.APP_WORKER,
});

if (result.err) {
  return Astro.redirect("/?error=fetch_failed");
}

const { installed, notInstalled, sidebarGuilds } = result.val;
const botClientId = env.DISCORD_BOT_CLIENT_ID;
---

<Dashboard title={t(locale, "dashboard.servers")} description={t(locale, "meta.dashboard.description")} guilds={sidebarGuilds}>
  <div class="mx-auto max-w-7xl space-y-10">
    <div class="space-y-2">
      <h1 class="font-heading text-3xl font-extrabold tracking-tight text-on-surface sm:text-4xl">{t(locale, "dashboard.servers")}</h1>
      <p class="text-on-surface-variant">
        {t(locale, "dashboard.servers.desc")}
      </p>
    </div>

    {
      installed.length > 0 && (
        <section class="space-y-4">
          <h2 class="font-heading text-lg font-bold text-on-surface">{t(locale, "dashboard.installed")}</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {installed.map((guild) => (
              <GuildCard guild={guild} botClientId={botClientId} />
            ))}
          </div>
        </section>
      )
    }

    {
      notInstalled.length > 0 && (
        <section class="space-y-4">
          <h2 class="font-heading text-lg font-bold text-on-surface-variant">
            {t(locale, "dashboard.notInstalled")}
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {notInstalled.map((guild) => (
              <GuildCard guild={guild} botClientId={botClientId} />
            ))}
          </div>
        </section>
      )
    }

    {
      installed.length === 0 && notInstalled.length === 0 && (
        <p class="text-on-surface-variant">
          {t(locale, "dashboard.noServers")}
        </p>
      )
    }
  </div>
</Dashboard>
