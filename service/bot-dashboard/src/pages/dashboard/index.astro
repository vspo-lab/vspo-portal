---
import { env } from "cloudflare:workers";
import { DISCORD_BOT_CLIENT_ID } from "astro:env/server";
import ErrorAlert from "~/features/shared/components/ErrorAlert.astro";
import GuildCard from "~/features/guild/components/GuildCard.astro";
import Dashboard from "~/layouts/Dashboard.astro";
import { ListGuildsUsecase } from "~/features/guild/usecase/list-guilds";
import { t } from "~/i18n/dict";

const locale = Astro.locals.locale;
const accessToken = Astro.locals.accessToken;
const user = Astro.locals.user;
if (!accessToken || !user) {
  return Astro.redirect("/");
}

const result = await ListGuildsUsecase.execute({
  accessToken,
  userId: user.id,
  appWorker: env.APP_WORKER,
});

const fetchError = result.err ?? null;
const installed = result.err ? [] : result.val.installed;
const notInstalled = result.err ? [] : result.val.notInstalled;
const botClientId = DISCORD_BOT_CLIENT_ID;

// Cache guild summaries in session for fast access on guild detail pages
if (!result.err) {
  const allGuilds = [...result.val.installed, ...result.val.notInstalled];
  Astro.session?.set(
    "guildSummaries",
    allGuilds.map((g) => ({ id: g.id, name: g.name, icon: g.icon, isAdmin: g.isAdmin, botInstalled: g.botInstalled })),
  );
}
---

<Dashboard title={t(locale, "dashboard.servers")} description={t(locale, "meta.dashboard.description")} showSidebar>
  <div class="mx-auto max-w-7xl space-y-10">
    <div class="space-y-2">
      <h1 class="font-heading text-3xl font-extrabold tracking-tight text-on-surface sm:text-4xl">{t(locale, "dashboard.servers")}</h1>
      <p class="text-on-surface-variant">
        {t(locale, "dashboard.servers.desc")}
      </p>
    </div>

    {fetchError && (
      <ErrorAlert message={t(locale, "error.fetch_failed")} retryHref="/dashboard" retryLabel={t(locale, "toast.retry")} />
    )}

    {
      installed.length > 0 && (
        <section class="space-y-4">
          <h2 class="font-heading text-lg font-bold text-on-surface">{t(locale, "dashboard.installed")}</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {installed.map((guild) => (
              <GuildCard guild={guild} botClientId={botClientId} />
            ))}
          </div>
        </section>
      )
    }

    {
      notInstalled.length > 0 && (
        <section class="space-y-4">
          <h2 class="font-heading text-lg font-bold text-on-surface-variant">
            {t(locale, "dashboard.notInstalled")}
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {notInstalled.map((guild) => (
              <GuildCard guild={guild} botClientId={botClientId} />
            ))}
          </div>
        </section>
      )
    }

    {
      !fetchError && installed.length === 0 && notInstalled.length === 0 && (
        <p class="text-on-surface-variant">
          {t(locale, "dashboard.noServers")}
        </p>
      )
    }
  </div>
</Dashboard>
