---
import { actions } from "astro:actions";
import Button from "~/features/shared/components/Button.astro";
import { env } from "cloudflare:workers";
import ChannelAddModal from "~/features/channel/components/ChannelAddModal.astro";
import ChannelConfigForm from "~/features/channel/components/ChannelConfigForm.astro";
import ChannelTable from "~/features/channel/components/ChannelTable.astro";
import DeleteChannelDialog from "~/features/channel/components/DeleteChannelDialog.astro";
import ErrorAlert from "~/features/shared/components/ErrorAlert.astro";
import FlashMessage from "~/features/shared/components/FlashMessage.astro";
import Dashboard from "~/layouts/Dashboard.astro";
import { VspoChannelApiRepository } from "~/features/channel/repository/vspo-channel-api";
import { GuildSummary } from "~/features/guild/domain/guild";
import { ListGuildsUsecase } from "~/features/guild/usecase/list-guilds";
import { t, memberTypeKey, languageDisplayKey } from "~/i18n/dict";

const locale = Astro.locals.locale;
const { guildId } = Astro.params;
if (!guildId) {
  return Astro.redirect("/dashboard");
}

const accessToken = Astro.locals.accessToken;
const user = Astro.locals.user;
if (!accessToken || !user) {
  return Astro.redirect("/");
}

// Check for action results (form submissions)
const addResult = Astro.getActionResult(actions.addChannel);
const updateResult = Astro.getActionResult(actions.updateChannel);
const deleteResult = Astro.getActionResult(actions.deleteChannel);
const resetResult = Astro.getActionResult(actions.resetChannel);

// If an action succeeded, redirect to refresh the page data
if (addResult?.data?.success || updateResult?.data?.success || deleteResult?.data?.success || resetResult?.data?.success) {
  const flashType = addResult?.data ? "add" : updateResult?.data ? "update" : deleteResult?.data ? "delete" : "reset";
  return Astro.redirect(`/dashboard/${guildId}?flash=${flashType}`);
}

// Check for flash message from redirect
const flashType = Astro.url.searchParams.get("flash");
const flashMessages: Record<string, string> = {
  add: t(locale, "toast.addSuccess"),
  update: t(locale, "toast.updateSuccess"),
  delete: t(locale, "toast.deleteSuccess"),
  reset: t(locale, "toast.resetSuccess"),
};

// Get action error if any
const actionError = addResult?.error ?? updateResult?.error ?? deleteResult?.error ?? resetResult?.error ?? null;

// Use cached guild summaries from session (set by /dashboard) to avoid the heavy
// ListGuildsUsecase call on every guild detail navigation.
// Falls back to the full fetch only on direct navigation (e.g. bookmark).
const cachedGuilds = await Astro.session?.get("guildSummaries");
const cachedGuild = cachedGuilds?.find((g) => g.id === guildId);

const [guildsResult, channelsResult, creatorsResult] = await Promise.all([
  cachedGuild
    ? Promise.resolve(null)
    : ListGuildsUsecase.execute({ accessToken, userId: user.id, appWorker: env.APP_WORKER, includeChannelSummary: false }),
  VspoChannelApiRepository.getGuildConfig(env.APP_WORKER, guildId),
  VspoChannelApiRepository.listCreators(env.APP_WORKER),
]);

const currentGuild = cachedGuild
  ? { id: cachedGuild.id, name: cachedGuild.name, icon: cachedGuild.icon, isAdmin: cachedGuild.isAdmin, botInstalled: cachedGuild.botInstalled }
  : (() => {
      const all = guildsResult?.err ? [] : [...(guildsResult?.val.installed ?? []), ...(guildsResult?.val.notInstalled ?? [])];
      return all.find((g) => g.id === guildId) ?? null;
    })();
const guildName = currentGuild?.name ?? guildId;
const channels = channelsResult.err ? [] : channelsResult.val.channels;
const creators = creatorsResult.err ? { jp: [], en: [] } : creatorsResult.val;
const fetchError = channelsResult.err ?? creatorsResult.err ?? null;


---

<Dashboard title={guildName} description={t(locale, "meta.guildDetail.description", { guildName })} showSidebar activeGuild={currentGuild ? { id: currentGuild.id, name: currentGuild.name, iconUrl: GuildSummary.iconUrl(currentGuild) } : null}>
  <div class="mx-auto max-w-7xl space-y-10">
    {/* Breadcrumb */}
    <nav aria-label={t(locale, "nav.breadcrumb")} class="text-sm">
      <ol class="flex items-center gap-1.5 text-on-surface-variant">
        <li>
          <a href="/dashboard" class="transition-colors hover:text-on-surface">{t(locale, "dashboard.allServers")}</a>
        </li>
        <li role="presentation">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </li>
        <li>
          <span class="font-medium text-on-surface">{guildName}</span>
        </li>
      </ol>
    </nav>

    {/* Page header */}
    <div class="flex items-end justify-between">
      <div class="space-y-2">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-vspo-purple">{t(locale, "nav.channels")}</p>
        <h1 class="font-heading text-3xl font-extrabold text-on-surface sm:text-4xl">{guildName}</h1>
        <p class="max-w-md text-on-surface-variant">
          {t(locale, "dashboard.channelsCount", { total: String(channels.length) })}
        </p>
      </div>
      <Button as="button" type="button" variant="primary" data-action-add class="gap-2 sm:hidden">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
        {t(locale, "channel.add")}
      </Button>
    </div>

    {/* Stats Bento Grid */}
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 sm:gap-6">
      <div class="rounded-2xl bg-surface-container-low p-6">
        <p class="mb-2 text-xs font-medium text-on-surface-variant">{t(locale, "dashboard.stat.channels")}</p>
        <span class="font-heading text-3xl font-bold text-on-surface">{channels.length}</span>
      </div>
      <div class="rounded-2xl bg-surface-container-low p-6">
        <p class="mb-2 text-xs font-medium text-on-surface-variant">{t(locale, "channel.language")}</p>
        <div class="flex gap-2">
          {[...new Set(channels.map(c => c.language))].map(lang => (
            <span class="rounded bg-surface-container-highest px-2 py-0.5 text-[10px] font-bold text-vspo-purple">{t(locale, languageDisplayKey(lang))}</span>
          ))}
          {channels.length === 0 && <span class="text-sm text-on-surface-variant">—</span>}
        </div>
      </div>
      <div class="col-span-2 rounded-2xl bg-surface-container-low p-6">
        <p class="mb-2 text-xs font-medium text-on-surface-variant">{t(locale, "channel.members")}</p>
        <div class="flex flex-wrap gap-2">
          {[...new Set(channels.map(c => c.memberType))].map(mt => (
            <span class="text-sm font-medium text-on-surface">{t(locale, memberTypeKey(mt))}</span>
          ))}
          {channels.length === 0 && <span class="text-sm text-on-surface-variant">—</span>}
        </div>
      </div>
    </div>

    {/* Alerts container */}
    <div class="space-y-4">
      {flashType && flashMessages[flashType] && (
        <FlashMessage result={{ data: { success: true } }} successMessage={flashMessages[flashType]} />
      )}
      {actionError && (
        <FlashMessage result={{ error: { message: actionError.message } }} />
      )}
      {fetchError && (
        <ErrorAlert message={t(locale, "dashboard.error", { message: fetchError.message })} retryHref={`/dashboard/${guildId}`} retryLabel={t(locale, "toast.retry")} />
      )}
    </div>

    {/* Configuration Matrix */}
    <ChannelTable channels={channels} />

    {/* Hidden modals */}
    <ChannelConfigForm
      creators={[...creators.jp, ...creators.en]}
      guildId={guildId}
      channels={channels}
      titleTemplate={t(locale, 'channelConfig.title', { channelName: '{channelName}' })}
      selectedTemplate={t(locale, 'channelConfig.members.selected', { count: '{count}' })}
    />

    <DeleteChannelDialog guildId={guildId} />

    <ChannelAddModal guildId={guildId} />
  </div>

</Dashboard>

<script>
  // Close open dialogs before page transition to prevent stale top-layer state
  document.addEventListener("astro:before-preparation", () => {
    for (const d of document.querySelectorAll("dialog[open]")) (d as HTMLDialogElement).close();
  });

  document.addEventListener("astro:after-swap", () => {
    for (const d of document.querySelectorAll("dialog[open]")) (d as HTMLDialogElement).close();
  });
</script>
