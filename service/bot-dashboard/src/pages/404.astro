---
import Base from "~/layouts/Base.astro";
import { t } from "~/i18n/dict";

const { locale } = Astro.locals;
---

<Base title="404" noindex>
  <div class="flex min-h-screen flex-col items-center justify-center bg-surface px-4 text-center">
    <div class="pointer-events-none absolute left-1/2 top-1/3 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 opacity-20" aria-hidden="true">
      <div class="absolute inset-0 rounded-full bg-gradient-to-b from-vspo-purple to-transparent blur-[100px]"></div>
    </div>

    <h1 class="relative z-10 font-heading text-7xl font-extrabold tracking-tight text-on-surface sm:text-9xl">404</h1>
    <p class="relative z-10 mt-4 text-lg text-on-surface-variant">
      {locale === "ja" ? "ページが見つかりませんでした" : "Page not found"}
    </p>
    <a
      href="/dashboard"
      class="relative z-10 mt-8 inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-vspo-purple to-[#bec2ff] px-6 py-3 font-heading text-sm font-bold text-white shadow-lg shadow-vspo-purple/20 transition-all hover:scale-[1.02] active:scale-95"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" /></svg>
      {locale === "ja" ? "ダッシュボードに戻る" : "Back to Dashboard"}
    </a>
  </div>
</Base>
