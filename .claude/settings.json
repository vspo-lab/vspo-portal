{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": "./docs/plan",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Skill:*",
      "TodoRead(*)",
      "TodoWrite(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Bash(./scripts/*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(chmod -R 777 /)",
      "Bash(> /dev/sda*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(pnpm publish*)",
      "Bash(npm publish*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-bash-command.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/mark-post-edit-needed.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-post-edit-check-if-needed.sh"
          }
        ]
      }
    ]
  }
}
